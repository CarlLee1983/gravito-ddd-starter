# ============================================================================
# Gravito DDD 應用程式 - 環境設定範例
# ============================================================================
# 複製此檔案為 .env 並根據實際環境設定相應的值
# 注意：敏感資訊（如密碼、API key）不應提交到版本控制，請使用 .env.local
#
# 快速開始：
# - 本機開發: cp .env.example .env && bun dev
# - Docker: docker-compose up -d && cp .env.example .env (修改下面的 DOCKER 段落)

# ============================================================================
# 應用程式基本設定
# ============================================================================
# 應用程式名稱 (預設: cmg-station-ddd)
APP_NAME=cmg-station-ddd

# 應用程式環境 (development, staging, production)
APP_ENV=development

# 應用程式 URL (用於郵件、重定向等)
APP_URL=http://localhost:3000

# 應用程式連接埠 (預設: 3000)
PORT=3000

# 應用程式調試模式 (true/false)
APP_DEBUG=true

# Node.js 環境 (development, production)
NODE_ENV=development

# ============================================================================
# 資料庫設定 - SQLite（本機開發推薦）
# ============================================================================
# 是否啟用資料庫 (true/false，任何非 'false' 的值都表示啟用)
ENABLE_DB=true

# 資料庫連接類型 (sqlite, postgres, mysql)
# 建議：
#   - 本機開發: sqlite
#   - Docker: postgres
DB_CONNECTION=sqlite

# SQLite 資料庫檔案路徑 (DB_CONNECTION=sqlite 時使用)
DB_DATABASE=database/database.sqlite

# ============================================================================
# 資料庫設定 - PostgreSQL（Docker / 生產環境）
# ============================================================================
# 取消註解以下設定並註解上面的 SQLite 設定，即可切換到 PostgreSQL
#
# DB_CONNECTION=postgres
# DB_HOST=localhost          # 本機: localhost | Docker: gravito-postgres
# DB_PORT=5432
# DB_DATABASE=gravito_ddd
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_SSLMODE=prefer

# PostgreSQL 連接池配置（可選）
# DB_POOL_MIN=2
# DB_POOL_MAX=10
# DB_POOL_IDLE_TIMEOUT=30000
# DB_POOL_CONNECTION_TIMEOUT=5000

# ============================================================================
# Redis 設定
# ============================================================================
# Redis 主機
# 本機: 127.0.0.1 | Docker Compose: gravito-redis
REDIS_HOST=127.0.0.1

# Redis 連接埠 (預設: 6379)
# 本機: 6379 | Docker Compose: 6380 (映射到容器 6379)
REDIS_PORT=6379

# Redis 密碼 (若無密碼留空)
# REDIS_PASSWORD=

# Redis 資料庫編號（預設: 0）
REDIS_DB=0

# ============================================================================
# 快取設定
# ============================================================================
# 快取驅動程式 (memory, file, redis)
# 推薦：
#   - 開發環境: memory (快速，進程重啟丟失)
#   - 生產環境: redis (持久化，支援多進程)
CACHE_DRIVER=memory

# 檔案系統快取路徑 (CACHE_DRIVER=file 時使用)
CACHE_PATH=storage/framework/cache

# Redis 快取連接 (CACHE_DRIVER=redis 時使用)
# REDIS_CACHE_CONNECTION=default

# Redis 快取前綴 (預設: cache:)
# REDIS_CACHE_PREFIX=cache:

# ============================================================================
# 隊列與事件設定
# ============================================================================
# 事件驅動程式選擇 (memory, redis, rabbitmq)
# 推薦：
#   - 本機開發: memory (簡單，進程內)
#   - Docker/生產: redis (持久化，支援多進程)
#   - 大規模系統: rabbitmq (複雜路由，死信隊列)
EVENT_DRIVER=memory

# ============================================================================
# Redis 事件隊列配置 (EVENT_DRIVER=redis 時)
# ============================================================================
# Redis 隊列連接
# REDIS_QUEUE_CONNECTION=default

# 事件隊列名稱 (預設: domain_events_queue)
# REDIS_EVENTS_QUEUE=domain_events_queue

# 工作隊列名稱 (預設: system_jobs_queue)
# REDIS_JOBS_QUEUE=system_jobs_queue

# Worker 輪詢間隔 (毫秒，預設: 1000)
# QUEUE_POLLING_INTERVAL=1000

# Worker 輪詢超時 (毫秒，預設: 30000)
# QUEUE_POLLING_TIMEOUT=30000

# ============================================================================
# RabbitMQ 隊列配置 (EVENT_DRIVER=rabbitmq 時)
# ============================================================================
# RabbitMQ 連接 URL
# 格式: amqp://username:password@host:port/vhost
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# RabbitMQ 連接詳細參數 (RABBITMQ_URL 優先級更高)
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASS=guest
# RABBITMQ_VHOST=/

# RabbitMQ 消費者配置
# RABBITMQ_PREFETCH=1              # 預取消息數
# RABBITMQ_CONSUMER_TIMEOUT=30000  # 消費超時 (毫秒)

# RabbitMQ 重連策略
# RABBITMQ_RECONNECT_ATTEMPTS=10   # 最大重連次數
# RABBITMQ_RECONNECT_DELAY=1000    # 初始延遲 (毫秒)
# RABBITMQ_RECONNECT_MAX_DELAY=30000  # 最大延遲 (毫秒)

# ============================================================================
# Job 隊列配置
# ============================================================================
# Job 重試次數 (預設: 3)
# JOB_RETRIES=3

# Job 重試延遲 (秒，預設: 60)
# JOB_BACKOFF=60

# Job 延遲執行時間 (秒，預設: 0)
# JOB_DELAY=0

# ============================================================================
# Event 配置
# ============================================================================
# 事件序列化格式 (json)
# EVENT_SERIALIZATION=json

# 是否記錄事件日誌 (true/false，預設: false)
# EVENT_LOGGING=false

# ============================================================================
# 儲存設定 (文件管理)
# ============================================================================
# 預設儲存磁碟 (local, s3)
DRIVE_DISK=local

# 本地儲存根目錄 (預設: ./storage)
DRIVE_LOCAL_ROOT=./storage

# S3 儲存設定 (DRIVE_DISK=s3 或需要 S3 時配置)
# S3_KEY=
# S3_SECRET=
# S3_BUCKET=
# S3_REGION=us-east-1

# ============================================================================
# 檢視與靜態資源設定
# ============================================================================
# 檢視檔案目錄 (預設: src/views)
VIEW_DIR=src/views

# 靜態資源版本 (用於 cache busting)
VITE_ASSET_VERSION=1

# ============================================================================
# JWT 設定（認證系統）
# ============================================================================
# JWT 密鑰 (用於簽署和驗證 Token)
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=your_secret_key_here_at_least_32_characters

# JWT 過期時間 (預設: 24h)
# JWT_EXPIRATION=24h

# ============================================================================
# 郵件設定（可選）
# ============================================================================
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=465
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS=noreply@example.com
# MAIL_FROM_NAME="Gravito DDD"

# ============================================================================
# 環境配置預設集
# ============================================================================
#
# 【本機開發（推薦 SQLite）】
# ├─ DB_CONNECTION=sqlite
# ├─ EVENT_DRIVER=memory
# ├─ CACHE_DRIVER=memory
# └─ REDIS_HOST=127.0.0.1
#
# 【本機開發（PostgreSQL 本機連線）】
# ├─ DB_CONNECTION=postgres
# ├─ DB_HOST=localhost
# ├─ DB_PORT=5432
# ├─ EVENT_DRIVER=memory
# ├─ CACHE_DRIVER=memory
# └─ REDIS_HOST=127.0.0.1
#
# 【Docker Compose 開發環境】
# ├─ DB_CONNECTION=postgres
# ├─ DB_HOST=gravito-postgres
# ├─ DB_PORT=5432
# ├─ REDIS_HOST=gravito-redis
# ├─ REDIS_PORT=6379
# ├─ EVENT_DRIVER=redis
# └─ CACHE_DRIVER=redis
#
# 【生產環境（推薦 Redis）】
# ├─ DB_CONNECTION=postgres
# ├─ DB_HOST=prod-postgres.internal
# ├─ REDIS_HOST=prod-redis.internal
# ├─ REDIS_PASSWORD=secure_password
# ├─ EVENT_DRIVER=redis
# ├─ CACHE_DRIVER=redis
# └─ NODE_ENV=production
#
# 【生產環境（高可用 RabbitMQ）】
# ├─ DB_CONNECTION=postgres
# ├─ EVENT_DRIVER=rabbitmq
# ├─ RABBITMQ_URL=amqp://user:pass@rabbitmq:5672/
# └─ CACHE_DRIVER=redis

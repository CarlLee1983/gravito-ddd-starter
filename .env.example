# 應用程式配置

# ORM 選擇 - 決定使用哪個 Repository 實現
# 支援值：memory (開發/測試), drizzle (生產), atlas (未來), prisma (未來)
#
# ORM=memory    → 使用 UserRepository (in-memory)、PostRepository (in-memory)
# ORM=drizzle   → 使用 DrizzleUserRepository (db)、DrizzlePostRepository (db)
ORM=memory

# 資料庫配置 - 當 ORM=drizzle 時使用
# 格式：SQLite 檔案路徑 或 PostgreSQL 連接字串
#
# SQLite (本地開發):
# DATABASE_URL=file:./data.db
#
# PostgreSQL (遠端生產):
# DATABASE_URL=postgresql://user:password@hostname:5432/database
DATABASE_URL=file:./data.db

# 應用程式埠
PORT=3000

# 環境
NODE_ENV=development

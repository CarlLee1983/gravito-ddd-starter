# ============================================================================
# Gravito DDD 應用程式 - 環境設定範例
# ============================================================================
# 複製此檔案為 .env 並根據實際環境設定相應的值
# 注意：敏感資訊（如密碼、API key）不應提交到版本控制，請使用 .env.local

# ============================================================================
# 應用程式基本設定
# ============================================================================
# 應用程式名稱 (預設: cmg-station-ddd)
APP_NAME=cmg-station-ddd

# 應用程式環境 (development, staging, production)
APP_ENV=development

# 應用程式 URL (用於郵件、重定向等)
APP_URL=http://localhost:3000

# 應用程式連接埠 (預設: 3000)
PORT=3000

# 應用程式調試模式 (true/false)
APP_DEBUG=true

# Node.js 環境 (development, production)
NODE_ENV=development

# ============================================================================
# 資料庫設定
# ============================================================================
# 是否啟用資料庫 (true/false，任何非 'false' 的值都表示啟用)
ENABLE_DB=true

# 資料庫連接類型 (sqlite, postgres, mysql)
DB_CONNECTION=sqlite

# SQLite 資料庫檔案路徑 (DB_CONNECTION=sqlite 時使用)
DB_DATABASE=database/database.sqlite

# PostgreSQL/MySQL 主機 (預設: 127.0.0.1)
DB_HOST=127.0.0.1

# PostgreSQL/MySQL 連接埠
# - PostgreSQL: 5432
# - MySQL: 3306
DB_PORT=5432

# PostgreSQL/MySQL 資料庫名稱 (預設: gravito)
# DB_DATABASE=gravito

# PostgreSQL/MySQL 使用者名稱
# - PostgreSQL: postgres
# - MySQL: root
# DB_USERNAME=postgres

# PostgreSQL/MySQL 密碼
# DB_PASSWORD=

# PostgreSQL SSL 模式 (disable, allow, prefer, require, verify-ca, verify-full)
DB_SSLMODE=prefer

# ============================================================================
# Redis 設定
# ============================================================================
# Redis 主機 (預設: 127.0.0.1)
REDIS_HOST=127.0.0.1

# Redis 連接埠 (預設: 6379)
REDIS_PORT=6379

# Redis 密碼 (若無密碼留空)
# REDIS_PASSWORD=

# ============================================================================
# 快取設定
# ============================================================================
# 快取驅動程式 (memory, file, redis)
# - memory: 內存快取（開發環境推薦）
# - file: 檔案系統快取
# - redis: Redis 快取（生產環境推薦）
CACHE_DRIVER=memory

# 檔案系統快取路徑 (CACHE_DRIVER=file 時使用)
CACHE_PATH=storage/framework/cache

# Redis 快取連接 (CACHE_DRIVER=redis 時使用)
REDIS_CACHE_CONNECTION=default

# Redis 快取前綴 (預設: cache:)
REDIS_CACHE_PREFIX=cache:

# ============================================================================
# 儲存設定 (文件管理)
# ============================================================================
# 預設儲存磁碟 (local, s3)
DRIVE_DISK=local

# 本地儲存根目錄 (預設: ./storage)
DRIVE_LOCAL_ROOT=./storage

# S3 儲存設定 (DRIVE_DISK=s3 或需要 S3 時配置)
# S3_KEY=
# S3_SECRET=
# S3_BUCKET=
# S3_REGION=us-east-1

# ============================================================================
# 事件驅動設定
# ============================================================================
# 事件驅動器類型 (sync, queue)
# - sync: 同步事件分派（開發環境推薦）
# - queue: 異步隊列事件分派（生產環境推薦）
EVENT_DRIVER=sync

# ============================================================================
# 檢視與靜態資源設定
# ============================================================================
# 檢視檔案目錄 (預設: src/views)
VIEW_DIR=src/views

# 靜態資源版本 (用於 cache busting)
VITE_ASSET_VERSION=1

# ============================================================================
# 框架選擇 (Gravito 專用)
# ============================================================================
# 使用的 ORM (memory, atlas, drizzle)
# 注意：此設定主要用於開發和測試選擇，生產環境應使用 DB_CONNECTION
# ORM=memory

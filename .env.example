################################################################################
#                     Gravito DDD Starter - Configuration
################################################################################
# Copy this file to .env and adjust values for your environment.
# Variables are loaded from .env during app initialization.
# Type: All values are strings unless noted otherwise.

################################################################################
#                         Application Core
################################################################################

# APP_NAME: Unique identifier for your application
# Used in logs, metrics, and third-party integrations
# Example: "my-ddd-app", "order-service", "payment-gateway"
APP_NAME=gravito-ddd-starter

# APP_ENV: Deployment environment (affects logging, debugging, feature flags)
# Allowed values: "development", "staging", "production"
# - development: Verbose logging, debug mode enabled, slower but informative
# - staging: Production-like config but with debug endpoints
# - production: Minimal logging, optimized performance, strict error handling
# Default: "development"
APP_ENV=development

# APP_DEBUG: Enable/disable debug mode (affects startup logs and error details)
# Set to "false" in production to hide sensitive information in error responses
# Type: boolean (string "true"/"false")
# Default: true
APP_DEBUG=true

# PORT: HTTP server port
# The application will listen on http://localhost:{PORT}
# Type: number
# Default: 3000
# Common ports: 3000 (dev), 8000 (alt dev), 80 (http), 443 (https)
PORT=3000

# APP_URL: Full URL of the application (used in emails, links, verification tokens)
# Must be accessible from the internet if used for email verification links
# Example: "http://localhost:3000" (development), "https://api.example.com" (production)
APP_URL=http://localhost:3000

################################################################################
#                         Database Configuration (OrbitAtlas)
################################################################################
# Gravito uses Atlas ORM (query builder, not migration tool)
# Database is optional - set ENABLE_DB=false to run without persistence

# ENABLE_DB: Enable/disable database connectivity
# Set to "false" to run application without database (in-memory only)
# Type: boolean (string "true"/"false")
# Default: true
ENABLE_DB=true

# DB_CONNECTION: Database driver to use
# Supported: "sqlite", "postgres", "mysql"
# - sqlite: File-based, no server needed, perfect for development
# - postgres: Production-grade relational database
# - mysql: Alternative relational database
# Default: "sqlite"
DB_CONNECTION=sqlite

# DB_DATABASE: SQLite file path (only used when DB_CONNECTION=sqlite)
# Creates file automatically if it doesn't exist
# Relative paths are relative to project root
# Default: "database/database.sqlite"
DB_DATABASE=database/database.sqlite

# PostgreSQL Configuration
DB_CONNECTION=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=gravito
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSL=false

# MySQL Configuration (uncomment and set if using mysql)
# ──────────────────────────────────────────────────────────────
# DB_CONNECTION=mysql
# DB_HOST=localhost                  # Database server hostname
# DB_PORT=3306                       # MySQL default port
# DB_DATABASE=gravito                # Database name to connect to
# DB_USERNAME=root                   # Database user
# DB_PASSWORD=                       # Database password

################################################################################
#                         Cache Configuration (OrbitStasis)
################################################################################
# Caching layer for performance optimization
# Automatically caches query results, computed values, and aggregations

# CACHE_DRIVER: Cache storage backend
# Supported: "memory", "file", "redis"
# - memory: In-process memory, fastest, cleared on restart (development)
# - file: Persistent disk-based cache (staging/production fallback)
# - redis: Distributed cache server, recommended for production
# Default: "memory"
# Note: When CACHE_DRIVER=redis, you must configure REDIS_* variables
CACHE_DRIVER=memory

################################################################################
#                         Redis Configuration (OrbitPlasma)
################################################################################
# Redis is used for distributed caching, session storage, and pub/sub messaging
# Required only when CACHE_DRIVER=redis
# Optional: Used by OrbitPlasma for real-time features

# REDIS_HOST: Redis server hostname or IP address
# Default: "127.0.0.1" (localhost)
# Production: Use your Redis cluster endpoint
REDIS_HOST=127.0.0.1

# REDIS_PORT: Redis server port
# Default: 6379 (standard Redis port)
# Type: number
REDIS_PORT=6379

# REDIS_PASSWORD: Redis authentication password (if required)
# Leave empty if Redis has no password (default for local development)
# Required for cloud Redis providers (AWS ElastiCache, Azure, etc.)
REDIS_PASSWORD=

# REDIS_TLS: Enable TLS for Redis connection
# Set to "true" when connecting to cloud Redis (AWS, Azure, etc.)
# Type: boolean
# Default: false
# REDIS_TLS=false

################################################################################
#                         Authentication & Email
################################################################################

# REQUIRE_EMAIL_VERIFICATION: Require users to verify email before account activation
# When true: User must click email link before account becomes active
# When false: Account becomes active immediately upon registration
# Type: boolean (string "true"/"false")
# Default: false
# Note: Requires email service configuration if enabled
REQUIRE_EMAIL_VERIFICATION=false

# SENDGRID_API_KEY: SendGrid API key for sending transactional emails
# Required only when REQUIRE_EMAIL_VERIFICATION=true
# Get key: https://app.sendgrid.com/settings/api_keys
# Format: "SG.xxxxxxxxxxxxxxxx-xxxxxxxxxxxxxxxx"
# DO NOT commit this key - use environment variables in production
# SENDGRID_API_KEY=

# SENDGRID_FROM_EMAIL: Email address to use as "From" field
# Must be verified in SendGrid account
# Example: "noreply@example.com", "support@example.com"
# Required when sending emails through SendGrid
# SENDGRID_FROM_EMAIL=noreply@example.com

################################################################################
#                         Logging & Debugging
################################################################################

# LOG_LEVEL: Minimum severity level for logs
# Supported: "debug", "info", "warn", "error"
# - debug: All messages (verbose, development only)
# - info: Informational messages and above (default)
# - warn: Warnings and errors only (production)
# - error: Errors only (critical issues)
# Type: string
# Default: "info"
# LOG_LEVEL=info

################################################################################
#                         Development Notes
################################################################################
#
# Starting the app:
#   bun run dev              # Watch mode with auto-reload
#   bun run build && bun run start  # Production mode
#
# Running tests:
#   bun test                 # Run all tests
#   bun test --watch        # Watch mode
#
# Linting & formatting:
#   bun run lint            # Check code style with Biome
#   bun run format          # Auto-format code with Biome
#
# Creating modules:
#   bun gravito module generate Order --ddd-type simple
#
# For more details, see:
#   - README.md
#   - docs/ARCHITECTURE.md
#   - docs/MODULE_GUIDE.md
#   - docs/TROUBLESHOOTING.md
#

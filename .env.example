# App Configuration
APP_NAME=cmg-station-ddd
APP_ENV=local
APP_DEBUG=true
PORT=3000

# Database (OrbitAtlas). Omit or set ENABLE_DB=false to run without DB.
ENABLE_DB=true
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# Optional: postgres/mysql
# DB_CONNECTION=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=gravito
# DB_USERNAME=postgres
# DB_PASSWORD=

# Cache (OrbitStasis). default store: memory | file | redis
CACHE_DRIVER=memory

# Redis (OrbitPlasma). Required when CACHE_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth: require email verification before account is active (default: false)
REQUIRE_EMAIL_VERIFICATION=false
# Base URL for verification links (e.g. https://example.com)
APP_URL=http://localhost:3000

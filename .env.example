# ============================================================================
# Gravito DDD 應用程式 - 環境設定範例
# ============================================================================
# 複製此檔案為 .env 並根據實際環境設定相應的值
# 注意：敏感資訊（如密碼、API key）不應提交到版本控制，請使用 .env.local
#
# 架構：
# 1. 應用程式基本設定
# 2. 資料庫設定
# 3. Redis 設定
# 4. 快取設定
# 5. 隊列與事件設定（新）
# 6. 儲存設定
# 7. 檢視與靜態資源設定

# ============================================================================
# 應用程式基本設定
# ============================================================================
# 應用程式名稱 (預設: cmg-station-ddd)
APP_NAME=cmg-station-ddd

# 應用程式環境 (development, staging, production)
APP_ENV=development

# 應用程式 URL (用於郵件、重定向等)
APP_URL=http://localhost:3000

# 應用程式連接埠 (預設: 3000)
PORT=3000

# 應用程式調試模式 (true/false)
APP_DEBUG=true

# Node.js 環境 (development, production)
NODE_ENV=development

# ============================================================================
# 資料庫設定
# ============================================================================
# 是否啟用資料庫 (true/false，任何非 'false' 的值都表示啟用)
ENABLE_DB=true

# 資料庫連接類型 (sqlite, postgres, mysql)
DB_CONNECTION=postgres

# SQLite 資料庫檔案路徑 (DB_CONNECTION=sqlite 時使用)
# DB_DATABASE=database/database.sqlite

# PostgreSQL/MySQL 主機 (預設: 127.0.0.1)
DB_HOST=127.0.0.1

# PostgreSQL/MySQL 連接埠
# - PostgreSQL: 5432
# - MySQL: 3306
DB_PORT=5432

# PostgreSQL/MySQL 資料庫名稱 (預設: gravito_ddd)
DB_DATABASE=gravito_ddd

# PostgreSQL/MySQL 使用者名稱
# - PostgreSQL: postgres
# - MySQL: root
DB_USERNAME=postgres

# PostgreSQL/MySQL 密碼
DB_PASSWORD=postgres

# PostgreSQL SSL 模式 (disable, allow, prefer, require, verify-ca, verify-full)
DB_SSLMODE=prefer

# ============================================================================
# Redis 設定
# ============================================================================
# Redis 主機 (預設: 127.0.0.1)
# Docker Compose 使用 gravito-redis，本機使用 127.0.0.1
REDIS_HOST=127.0.0.1

# Redis 連接埠 (預設: 6379)
# Docker Compose 映射到 6380，本機使用 6379
REDIS_PORT=6379

# Redis 密碼 (若無密碼留空)
# REDIS_PASSWORD=

# ============================================================================
# 快取設定
# ============================================================================
# 快取驅動程式 (memory, file, redis)
# - memory: 內存快取（開發環境推薦，進程重啟丟失）
# - file: 檔案系統快取
# - redis: Redis 快取（生產環境推薦，需配置 REDIS）
CACHE_DRIVER=memory

# 檔案系統快取路徑 (CACHE_DRIVER=file 時使用)
CACHE_PATH=storage/framework/cache

# Redis 快取連接 (CACHE_DRIVER=redis 時使用)
REDIS_CACHE_CONNECTION=default

# Redis 快取前綴 (預設: cache:)
REDIS_CACHE_PREFIX=cache:

# ============================================================================
# 隊列與事件設定 (Laravel-style Queue System)
# ============================================================================
# 隊列驅動選擇 (memory, redis, rabbitmq)
#
# 驅動說明：
# - memory: 進程內隊列，開發/測試環境推薦
#           ❌ 進程重啟丟失事件，❌ 無法跨進程通訊
# - redis: Redis 隊列，開發/生產環境推薦
#          ✅ 支援持久化，✅ 支援多進程，✅ 簡單配置
# - rabbitmq: RabbitMQ AMQP，高級功能/大規模系統
#             ✅ 強持久化，✅ 複雜路由，✅ 死信隊列
EVENT_DRIVER=memory

# ============================================================================
# Redis 隊列配置 (EVENT_DRIVER=redis 時)
# ============================================================================
# Redis 隊列連接（可與快取連接分離）
# REDIS_QUEUE_CONNECTION=default

# 事件隊列名稱 (預設: domain_events_queue)
# REDIS_EVENTS_QUEUE=domain_events_queue

# 工作隊列名稱 (預設: system_jobs_queue)
# REDIS_JOBS_QUEUE=system_jobs_queue

# Worker 輪詢間隔 (毫秒，預設: 1000)
# QUEUE_POLLING_INTERVAL=1000

# Worker 輪詢超時 (毫秒，預設: 30000)
# QUEUE_POLLING_TIMEOUT=30000

# ============================================================================
# RabbitMQ 隊列配置 (EVENT_DRIVER=rabbitmq 時)
# ============================================================================
# RabbitMQ 連接 URL
# 格式: amqp://username:password@host:port/vhost
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# RabbitMQ 連接詳細參數 (RABBITMQ_URL 優先級更高)
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASS=guest
# RABBITMQ_VHOST=/

# RabbitMQ 消費者配置
# RABBITMQ_PREFETCH=1              # 預取消息數
# RABBITMQ_CONSUMER_TIMEOUT=30000  # 消費超時 (毫秒)

# RabbitMQ 重連策略
# RABBITMQ_RECONNECT_ATTEMPTS=10   # 最大重連次數
# RABBITMQ_RECONNECT_DELAY=1000    # 初始延遲 (毫秒)
# RABBITMQ_RECONNECT_MAX_DELAY=30000  # 最大延遲 (毫秒)

# ============================================================================
# Job 隊列配置
# ============================================================================
# Job 重試次數 (預設: 3)
# JOB_RETRIES=3

# Job 重試延遲 (秒，預設: 60)
# JOB_BACKOFF=60

# Job 延遲執行時間 (秒，預設: 0)
# JOB_DELAY=0

# ============================================================================
# Event 配置
# ============================================================================
# 事件序列化格式 (json)
# EVENT_SERIALIZATION=json

# 是否記錄事件日誌 (true/false，預設: false)
# EVENT_LOGGING=false

# ============================================================================
# 儲存設定 (文件管理)
# ============================================================================
# 預設儲存磁碟 (local, s3)
DRIVE_DISK=local

# 本地儲存根目錄 (預設: ./storage)
DRIVE_LOCAL_ROOT=./storage

# S3 儲存設定 (DRIVE_DISK=s3 或需要 S3 時配置)
# S3_KEY=
# S3_SECRET=
# S3_BUCKET=
# S3_REGION=us-east-1

# ============================================================================
# 檢視與靜態資源設定
# ============================================================================
# 檢視檔案目錄 (預設: src/views)
VIEW_DIR=src/views

# 靜態資源版本 (用於 cache busting)
VITE_ASSET_VERSION=1

# ============================================================================
# 環境特定範例配置
# ============================================================================
#
# 開發環境（本機）：
# EVENT_DRIVER=memory
# CACHE_DRIVER=memory
#
# 開發環境（Docker）：
# EVENT_DRIVER=redis
# REDIS_HOST=gravito-redis
# REDIS_PORT=6379
# CACHE_DRIVER=redis
# REDIS_CACHE_CONNECTION=default
#
# 生產環境（推薦 Redis）：
# EVENT_DRIVER=redis
# REDIS_HOST=redis-server.internal
# REDIS_PORT=6379
# REDIS_PASSWORD=secure_password
# CACHE_DRIVER=redis
#
# 生產環境（進階 RabbitMQ）：
# EVENT_DRIVER=rabbitmq
# RABBITMQ_URL=amqp://user:pass@rabbitmq-server:5672/
# RABBITMQ_RECONNECT_ATTEMPTS=20
# RABBITMQ_PREFETCH=10
# CACHE_DRIVER=redis

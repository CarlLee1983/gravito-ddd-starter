# 編譯產物遺留物（應只在 dist/ 中）
config/**/*.js      # config 只保留源代碼
src/**/*.js         # src 只保留源代碼
database/**/*.js    # database 只保留源代碼
resources/**/*.js   # resources 只保留源代碼 (JSX/TSX)
tests/**/*.js       # tests 只保留源代碼
tests/**/*.d.ts     # tests 宣告檔
tests/**/*.map

# 宣告檔與源地圖（全局排除）

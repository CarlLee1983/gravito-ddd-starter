{
  "extends": "./tsconfig.json",

  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",

    // 生產優化（覆蓋 extends）
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "removeComments": true,

    // 忽略庫類型錯誤
    "skipLibCheck": true,
    "noImplicitAny": false
  },

  "include": ["src", "config"],
  "exclude": ["node_modules", "dist", "tests", "resources", "database", "**/*.test.ts", "**/*.spec.ts"]
}

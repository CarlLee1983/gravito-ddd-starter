# PostgreSQL Docker 環境配置
# 使用方式: cp .env.postgres .env && bun dev

# 資料庫連接配置
DB_CONNECTION=postgres
ENABLE_DB=true

# PostgreSQL 連接參數
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=gravito_ddd
DB_USER=postgres
DB_PASSWORD=postgres

# 連接池配置（可選）
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 應用配置
NODE_ENV=development

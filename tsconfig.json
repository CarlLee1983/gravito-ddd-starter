{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": "dist",
    "resolveJsonModule": true,
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./src/*"],
      "@gravito/prism": ["./node_modules/@gravito/prism/dist/index.js"],
      "@gravito/signal": ["./node_modules/@gravito/signal/dist/index.mjs"],
      "@gravito/stasis": ["./node_modules/@gravito/stasis/dist/index.js"]
    }
  },
  "include": ["src", "tests", "config", "types"],
  "exclude": ["node_modules", "dist"]
}

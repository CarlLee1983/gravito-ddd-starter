{
  "name": "gravito-ddd-starter",
  "version": "1.1.0",
  "description": "Clean Gravito DDD starter template - Generate your own modules with the CLI",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun run --hot bin/server.ts",
    "dev:watch": "tsx watch bin/server.ts",
    "dev:bun": "bun run --hot bin/server.ts",
    "dev:debug": "NODE_OPTIONS='--inspect-brk' node dist/index.js",
    "build": "bun run build:ts && bash scripts/build-cleanup.sh",
    "build:ts": "tsc --project config/tsconfig.prod.json",
    "build:staging": "NODE_ENV=staging bun run build",
    "build:prod": "NODE_ENV=production bun run build",
    "start": "node dist/src/index.js",
    "start:prod": "NODE_ENV=production node dist/src/index.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:unit": "bun test tests/Unit/",
    "test:integration": "bun test tests/Integration/",
    "test:feature": "bun test tests/Feature/",
    "test:user": "bun test tests/ --filter User",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src tests",
    "lint:fix": "biome lint src tests --fix",
    "format": "biome format src tests --write",
    "format:check": "biome format src tests --check",
    "check": "bun run typecheck && bun run lint && bun run test",
    "verify": "bun run check && echo '✅ All checks passed!' && echo '' && echo '📊 Coverage report generated in ./coverage'",
    "setup": "bun install && bash scripts/setup-hooks.sh && bun run verify",
    "troubleshoot": "bash scripts/troubleshoot.sh",
    "generate:module": "bun scripts/generate-module.ts",
    "setup:hooks": "bash scripts/setup-hooks.sh",
    "migrate": "bun orbit migrate",
    "migrate:rollback": "bun orbit migrate:rollback",
    "migrate:fresh": "bun orbit migrate:fresh",
    "migrate:status": "bun orbit migrate:status",
    "seed": "bun orbit seed",
    "db:fresh": "bun orbit migrate:fresh && bun orbit seed",
    "db:doctor": "bun orbit doctor",
    "make:migration": "bun orbit make:migration",
    "make:model": "bun orbit make:model",
    "make:controller": "bun gravito make:controller",
    "make:middleware": "bun gravito make:middleware",
    "make:command": "bun gravito make:command",
    "route:list": "bun gravito route:list",
    "tinker": "bun gravito tinker",
    "generate:types": "bun orbit generate:types"
  },
  "dependencies": {
    "@gravito/atlas": "^2.3.0",
    "@gravito/core": "^2.0.4",
    "@gravito/plasma": "^2.0.1",
    "@gravito/prism": "^3.1.1",
    "@gravito/sentinel": "^4.0.1",
    "@gravito/signal": "^3.1.0",
    "@gravito/stasis": "^3.2.1",
    "@inertiajs/react": "^2.3.17",
    "@libsql/client": "^0.17.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "glob": "^13.0.6",
    "lucide-react": "^0.577.0",
    "mongodb": "^7.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "overrides": {
    "@gravito/atlas": "$@gravito/atlas",
    "@gravito/core": "$@gravito/core",
    "@gravito/photon": "1.0.1",
    "@gravito/scaffold": "4.1.0",
    "@gravito/chromatic": "1.0.0"
  },
  "devDependencies": {
    "@gravito/pulse": "^3.4.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "biome": "latest",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.9",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}

{
  "name": "gravito-ddd-starter",
  "version": "1.0.0",
  "description": "Clean Gravito DDD starter template - Generate your own modules with the CLI",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "dev:debug": "NODE_OPTIONS='--inspect-brk' bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --format esm",
    "start": "bun dist/index.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:unit": "bun test tests/Unit/",
    "test:integration": "bun test tests/Integration/",
    "test:feature": "bun test tests/Feature/",
    "test:user": "bun test tests/ --filter User",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src tests",
    "lint:fix": "biome lint src tests --fix",
    "format": "biome format src tests --write",
    "format:check": "biome format src tests --check",
    "check": "bun run typecheck && bun run lint && bun run test",
    "generate:module": "bun add -D @gravito/pulse && bun gravito module generate"
  },
  "dependencies": {
    "@gravito/atlas": "^2.0.0",
    "@gravito/core": "^2.0.0",
    "@gravito/plasma": "^2.0.0",
    "@gravito/prism": "^3.1.1",
    "@gravito/sentinel": "^4.0.1",
    "@gravito/signal": "^3.1.0",
    "@gravito/stasis": "^3.2.0"
  },
  "overrides": {
    "@gravito/photon": "1.0.1",
    "@gravito/scaffold": "4.1.0",
    "@gravito/chromatic": "1.0.0"
  },
  "devDependencies": {
    "@gravito/pulse": "^3.4.0",
    "biome": "latest",
    "bun-types": "latest",
    "typescript": "^5.3.0"
  }
}
